---
import { SITE } from '../data/site';
---

<section class="principles">
  <div class="container">
    <header class="head">
      <p class="mono eyebrow">— Принципы</p>
      <h2>Четыре границы, которые мы не пересекаем</h2>
      <p class="lead">
        Они отсекают неподходящих клиентов до брифа,
        а нас самих — от компромиссов после.
      </p>
    </header>

    <div class="manifesto">
      {
        SITE.antiList.map((p) => (
          <p class="paragraph">
            <strong>{p.title}.</strong> {p.text}
          </p>
        ))
      }
    </div>
  </div>
</section>

<style>
  .principles {
    padding: 192px 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  /* Head — занимает почти всю ширину хедера, как монументальный анонс */
  .head {
    margin-bottom: 128px;
  }

  .head .eyebrow {
    margin-bottom: 32px;
  }

  .head h2 {
    font-size: clamp(32px, 4vw, 60px);
    font-weight: 400;
    letter-spacing: -0.03em;
    line-height: 1.05;
    text-wrap: balance;
    max-width: 1100px;
  }

  .head .lead {
    font-size: 19px;
    line-height: 1.55;
    color: var(--color-text-muted);
    margin-top: 40px;
    max-width: 56ch;
  }

  /* Manifesto — узкая editorial-колонка 680px, смещена вправо
     для editorial-асимметрии "тезис слева ↔ аргументация справа" */
  .manifesto {
    max-width: 680px;
    margin-left: auto;
    margin-right: 0;
  }

  .paragraph {
    font-size: 18px;
    line-height: 1.65;
    margin-bottom: 56px;
    color: var(--color-text);
  }

  .paragraph:last-child {
    margin-bottom: 0;
  }

  .paragraph strong {
    font-weight: 500;
    letter-spacing: -0.005em;
  }

  @media (max-width: 1024px) {
    .manifesto {
      margin-left: 0;
    }
  }

  @media (max-width: 720px) {
    .principles {
      padding: 96px 0;
    }
    .head {
      margin-bottom: 64px;
    }
    .head h2 {
      font-size: 30px;
    }
    .head .lead {
      font-size: 17px;
      margin-top: 28px;
    }
    .paragraph {
      font-size: 17px;
      margin-bottom: 36px;
    }
  }
</style>
