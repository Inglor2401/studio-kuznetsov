---
import { SITE } from '../data/site';
---

<section class="principles">
  <div class="container">
    <header class="head">
      <p class="mono eyebrow">— Принципы</p>
      <h2>Четыре границы, которые мы не пересекаем</h2>
      <p class="lead">
        Они отсекают неподходящих клиентов до брифа,
        а нас самих — от компромиссов после.
      </p>
    </header>

    {/* Editorial index — слева тематический лейбл крупным mono,
        справа разворачивание принципа. Левая колонка работает как
        визуальное оглавление манифеста, не как пустота. */}
    <div class="manifesto">
      {
        SITE.antiList.map((p) => (
          <article class="row">
            <div class="label-col">
              <span class="label mono">{p.label}</span>
            </div>
            <div class="text-col">
              <p class="paragraph">
                <strong>{p.title}.</strong> {p.text}
              </p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .principles {
    padding: 192px 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  /* Head — занимает почти всю ширину хедера, как монументальный анонс */
  .head {
    margin-bottom: 128px;
  }

  .head .eyebrow {
    margin-bottom: 32px;
  }

  .head h2 {
    font-size: clamp(32px, 4vw, 60px);
    font-weight: 400;
    letter-spacing: -0.03em;
    line-height: 1.05;
    text-wrap: balance;
    max-width: 1100px;
  }

  .head .lead {
    font-size: 19px;
    line-height: 1.55;
    color: var(--color-text-muted);
    margin-top: 40px;
    max-width: 56ch;
  }

  /* Manifesto — двухколоночный editorial index.
     Каждый принцип = одна строка grid: лейбл слева, тело справа. */
  .manifesto {
    display: grid;
    gap: 72px;
  }

  .row {
    display: grid;
    grid-template-columns: minmax(140px, 200px) minmax(0, 680px);
    gap: 96px;
    align-items: start;
  }

  .label-col {
    /* Лейбл выровнен по верхней линии текста справа.
       padding-top компенсирует разницу cap-height между mono и body. */
    padding-top: 6px;
  }

  .label {
    font-size: clamp(20px, 1.8vw, 28px);
    font-weight: 500;
    letter-spacing: 0.04em;
    line-height: 1;
    color: var(--color-text);
    display: inline-block;
  }

  .paragraph {
    font-size: 18px;
    line-height: 1.65;
    margin: 0;
    color: var(--color-text);
  }

  .paragraph strong {
    font-weight: 500;
    letter-spacing: -0.005em;
  }

  /* Tablet — сужаем gap, лейбл-колонку */
  @media (max-width: 1024px) {
    .row {
      grid-template-columns: minmax(120px, 160px) 1fr;
      gap: 56px;
    }
  }

  /* Mobile — стек: лейбл сверху, текст под ним */
  @media (max-width: 720px) {
    .principles {
      padding: 96px 0;
    }
    .head {
      margin-bottom: 64px;
    }
    .head h2 {
      font-size: 30px;
    }
    .head .lead {
      font-size: 17px;
      margin-top: 28px;
    }
    .manifesto {
      gap: 48px;
    }
    .row {
      grid-template-columns: 1fr;
      gap: 16px;
    }
    .label-col {
      padding-top: 0;
    }
    .label {
      font-size: 18px;
    }
    .paragraph {
      font-size: 17px;
    }
  }
</style>
