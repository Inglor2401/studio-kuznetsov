---
import { SITE } from '../data/site';
---

<section class="principles">
  <div class="container--text">
    <header class="lede">
      <h2>Четыре границы, которые мы не пересекаем</h2>
      <p>
        Они отсекают неподходящих клиентов до брифа,
        а нас самих — от компромиссов после.
      </p>
    </header>

    <ol class="list">
      {
        SITE.antiList.map((p) => (
          <li class="item">
            <h3 class="title">{p.title}</h3>
            <p class="text">{p.text}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .principles {
    padding: 160px 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .lede {
    margin-bottom: 96px;
    max-width: 880px;
  }

  .lede h2 {
    font-size: clamp(28px, 3vw, 44px);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.15;
  }

  .lede p {
    font-size: 17px;
    line-height: 1.6;
    color: var(--color-text-muted);
    max-width: 56ch;
    margin-top: 24px;
  }

  .list {
    list-style: none;
  }

  .item {
    display: block;
    padding: 48px 0;
    border-top: 1px solid var(--color-border);
  }

  .item:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .title {
    font-size: clamp(22px, 2.2vw, 28px);
    font-weight: 500;
    letter-spacing: -0.015em;
    line-height: 1.2;
    margin-bottom: 16px;
  }

  .text {
    font-size: 17px;
    line-height: 1.55;
    color: var(--color-text-muted);
    max-width: 60ch;
  }

  @media (max-width: 720px) {
    .principles {
      padding: 80px 0;
    }
    .lede {
      margin-bottom: 56px;
    }
    .item {
      padding: 32px 0;
    }
    .title {
      font-size: 20px;
    }
  }
</style>
