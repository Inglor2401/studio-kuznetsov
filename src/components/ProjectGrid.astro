---
import type { Project } from '../data/site';
import { SITE } from '../data/site';

interface Props {
  projects?: Project[];
}

const { projects = SITE.projects } = Astro.props;
---

<section class="project-grid">
  <ul>
    {
      projects.map((p) => (
        <li>
          <a href={`/projects/${p.slug}`} class="card">
            <div class="cover img-hover">
              <img src={p.cover} alt={p.title} loading="lazy" />
            </div>
            <div class="meta">
              <span class="mono num">{p.number}</span>
              <h3>{p.title}</h3>
              <span class="mono details">{p.location} · {p.area} m² · {p.year}</span>
            </div>
          </a>
        </li>
      ))
    }
  </ul>
</section>

<style>
  .project-grid ul {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 96px 32px;
    list-style: none;
  }

  .card {
    display: block;
    color: inherit;
  }

  .card:hover {
    opacity: 1;
  }

  .cover {
    aspect-ratio: 4 / 5;
    background: var(--color-surface-alt);
  }

  .meta {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 16px;
    align-items: baseline;
    margin-top: 20px;
  }

  .meta h3 {
    font-size: 18px;
    font-weight: 500;
    letter-spacing: -0.01em;
  }

  .num {
    white-space: nowrap;
  }

  .details {
    text-align: right;
    white-space: nowrap;
  }

  @media (max-width: 720px) {
    .project-grid ul {
      grid-template-columns: 1fr;
      gap: 64px;
    }
    .meta {
      grid-template-columns: auto 1fr;
    }
    .details {
      grid-column: 1 / 3;
      text-align: left;
    }
  }
</style>
