---
import { SITE } from '../data/site';
---

<footer class="site-footer">
  <div class="container">
    <div class="grid">
      <div class="col">
        <p class="mono label">Студия</p>
        <p>{SITE.studio.name}</p>
        <p>{SITE.studio.address}</p>
      </div>
      <div class="col">
        <p class="mono label">Контакт</p>
        <p>
          <a href={`mailto:${SITE.contact.email}`}>{SITE.contact.emailLabel}</a>
        </p>
        <p>
          <a href={SITE.contact.telegram}>{SITE.contact.telegramLabel}</a>
        </p>
        <p>
          <a href={`tel:${SITE.contact.phone.replace(/\s/g, '')}`}>{SITE.contact.phoneLabel}</a>
        </p>
      </div>
    </div>

    <div class="bottom">
      <p class="mono">© {new Date().getFullYear()} STUDIO KUZNETSOV</p>
      <p class="mono colophon">Onest · Geist Mono</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    padding: 96px 0 32px;
    margin-top: 128px;
  }

  .grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 96px;
    max-width: 800px;
  }

  .col p {
    margin-top: 4px;
    font-size: 14px;
  }

  .col p.label {
    margin-top: 0;
    margin-bottom: 16px;
  }

  .bottom {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-top: 64px;
    padding-top: 24px;
    border-top: 1px solid var(--color-border);
  }

  .colophon {
    color: var(--color-text-muted);
  }

  @media (max-width: 720px) {
    .site-footer {
      padding: 64px 0 24px;
      margin-top: 64px;
    }
    .grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .bottom {
      flex-direction: column;
      gap: 8px;
    }
  }
</style>
