---
import Layout from '../layouts/Layout.astro';
import { SITE } from '../data/site';
import ProjectGrid from '../components/ProjectGrid.astro';
import AntiList from '../components/AntiList.astro';

const featured = SITE.projects[0];
const restProjects = SITE.projects.slice(1);
---

<Layout
  pageType="home"
  ogImage="/og/default.png"
  preloadImage={featured.cover}
>
  {/* Hero — featured project full-bleed with editorial overlay */}
  <section class="hero">
    <a href={`/projects/${featured.slug}`} class="hero-link" aria-label={`Открыть проект: ${featured.title}`}>
      <img
        src={featured.cover}
        alt={`${featured.title} — резиденция ${featured.area} m² в районе ${featured.district}, Москва. Материалы: ${featured.materials}.`}
        fetchpriority="high"
        loading="eager"
      />
      <div class="hero-overlay">
        <div class="container">
          <p class="hero-tagline">{SITE.studio.bioShort}</p>
          <aside class="hero-meta mono">
            <p class="meta-eyebrow">{featured.number} / {featured.type}</p>
            <p class="meta-title">{featured.title}</p>
            <p>{featured.location} · {featured.area} m² · {featured.year}</p>
            <p class="meta-materials">{featured.materials}</p>
          </aside>
        </div>
      </div>
    </a>
  </section>

  {/* Project grid */}
  <section class="projects-section">
    <div class="container">
      <h2 class="section-h2">Избранные работы 2022–2024</h2>
      <ProjectGrid projects={restProjects} pattern="asymmetric" />
      <div class="all-link">
        <a href="/projects" class="btn">Все объекты →</a>
      </div>
    </div>
  </section>

  {/* Breathing pattern — full-bleed photo break (одна фотография как «вдох» между секциями) */}
  <section class="photo-break">
    <a href={`/projects/${SITE.projects[2].slug}`} class="img-hover" aria-label={`Открыть проект: ${SITE.projects[2].title}`}>
      <img
        src={SITE.projects[2].cover}
        alt={`${SITE.projects[2].title} — двусветная гостиная с центральным камином и видом на берёзовый лес.`}
        loading="lazy"
      />
    </a>
  </section>

  {/* Studio teaser */}
  <section class="studio-teaser">
    <div class="container">
      <p class="lead">{SITE.studio.bioShort}</p>
      <a href="/studio" class="btn">О студии →</a>
    </div>
  </section>

  <AntiList />

  {/* Press */}
  <section class="press">
    <div class="container--text">
      <h2 class="section-h2">Признание</h2>
      <ul>
        {
          SITE.press.map((item) => (
            <li>
              <div class="meta">
                <span class="mono pub">{item.publication}</span>
                <span class="mono year">{item.year}</span>
              </div>
              <span class="title">{item.title}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  {/* Contact CTA */}
  <section class="cta">
    <div class="container">
      <h2>Расскажите о проекте</h2>
      <p>Брифинг занимает 60 минут. Шоурум на Патриарших, по записи.</p>
      <a href="/contact" class="btn">Написать в студию →</a>
    </div>
  </section>
</Layout>

<style>
  /* Hero — full-bleed featured project + editorial overlay
     Tagline left + project marginalia right, gradient backdrop for legibility */
  .hero {
    position: relative;
    height: calc(100vh - 64px);  /* fill viewport minus header */
    overflow: hidden;
    background: var(--color-surface-alt);
  }
  .hero-link {
    display: block;
    width: 100%;
    height: 100%;
    position: relative;
    overflow: hidden;
    color: #FFFFFF;
  }
  .hero-link img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 1200ms var(--ease-out);
  }
  .hero-link:hover img {
    transform: scale(1.02);
    opacity: 1;
  }
  .hero-link:hover {
    opacity: 1;
  }

  .hero-overlay {
    position: absolute;
    inset: auto 0 0 0;
    padding-top: 160px;
    padding-bottom: 48px;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.55) 0%,
      rgba(0, 0, 0, 0.25) 50%,
      rgba(0, 0, 0, 0) 100%
    );
    pointer-events: none;
  }
  .hero-overlay > .container {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 48px;
  }

  .hero-tagline {
    font-size: clamp(20px, 2.4vw, 32px);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.2;
    color: #FFFFFF;
    max-width: 32ch;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.15);
  }

  .hero-meta {
    text-align: right;
    color: rgba(255, 255, 255, 0.95);
    flex-shrink: 0;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.15);
  }
  .hero-meta p {
    margin: 0;
    line-height: 1.5;
  }
  .hero-meta .meta-eyebrow {
    margin-bottom: 14px;
    color: #FFFFFF;
  }
  .hero-meta .meta-title {
    font-family: var(--font-sans);
    font-size: clamp(18px, 1.6vw, 22px);
    font-weight: 500;
    letter-spacing: -0.01em;
    text-transform: none;
    color: #FFFFFF;
    margin-bottom: 8px;
  }
  .hero-meta .meta-materials {
    margin-top: 6px;
    max-width: 36ch;
    color: rgba(255, 255, 255, 0.85);
  }

  .projects-section {
    padding: 96px 0;
    border-top: 1px solid var(--color-border);
  }
  .section-h2 {
    margin-bottom: 64px;
  }
  .all-link {
    margin-top: 96px;
    display: flex;
    justify-content: center;
  }

  /* Photo-break — breathing pause между плотными текстовыми секциями */
  .photo-break {
    width: 100%;
    height: 75vh;
    overflow: hidden;
    background: var(--color-surface-alt);
  }
  .photo-break a {
    display: block;
    width: 100%;
    height: 100%;
  }
  .photo-break img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .studio-teaser {
    padding: 192px 0;
    border-top: 1px solid var(--color-border);
  }
  .studio-teaser .lead {
    font-size: clamp(28px, 3.2vw, 44px);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin: 32px 0 48px;
    max-width: 1000px;
  }

  .press {
    padding: 128px 0;
  }
  .press ul {
    list-style: none;
    margin-top: 48px;
  }
  .press li {
    display: block;
    padding: 32px 0;
    border-top: 1px solid var(--color-border);
  }
  .press li:last-child {
    border-bottom: 1px solid var(--color-border);
  }
  .press .meta {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 24px;
    margin-bottom: 8px;
  }
  .press .pub {
    font-weight: 500;
  }
  .press .title {
    font-size: 22px;
    font-weight: 400;
    letter-spacing: -0.015em;
    line-height: 1.25;
    display: block;
  }

  .cta {
    padding: 192px 0;
    border-top: 1px solid var(--color-border);
  }
  .cta h2 {
    margin-bottom: 24px;
  }
  .cta p {
    margin-bottom: 48px;
    max-width: 600px;
    color: var(--color-text-muted);
    font-size: 18px;
  }

  @media (max-width: 720px) {
    .hero {
      height: calc(100vh - 56px);
      min-height: 560px;
    }
    .hero-overlay {
      padding-top: 96px;
      padding-bottom: 24px;
    }
    .hero-overlay > .container {
      flex-direction: column;
      align-items: flex-start;
      gap: 24px;
    }
    .hero-meta {
      text-align: left;
    }
    .hero-tagline {
      font-size: 20px;
    }
    .studio-teaser,
    .cta {
      padding: 96px 0;
    }
    .press li {
      padding: 24px 0;
    }
    .press .title {
      font-size: 18px;
    }
  }
</style>
