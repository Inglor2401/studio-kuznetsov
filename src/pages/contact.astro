---
import Layout from '../layouts/Layout.astro';
import { SITE } from '../data/site';
---

<Layout title="Контакт" description="Брифинг в шоуруме на Патриарших, по записи.">
  <section class="hero">
    <div class="container">
      <span class="mono">— Контакт</span>
      <h1>Брифинг занимает 60 минут</h1>
      <p class="lead">
        Шоурум на Патриарших, по записи. Договариваемся через любой удобный канал — почта,
        Telegram, телефон.
      </p>
    </div>
  </section>

  <section class="channels">
    <div class="container">
      <ul>
        <li>
          <span class="mono">Email</span>
          <a href={`mailto:${SITE.contact.email}`} class="big">{SITE.contact.emailLabel}</a>
        </li>
        <li>
          <span class="mono">Telegram</span>
          <a href={SITE.contact.telegram} class="big">{SITE.contact.telegramLabel}</a>
        </li>
        <li>
          <span class="mono">Телефон</span>
          <a href={`tel:${SITE.contact.phone.replace(/\s/g, '')}`} class="big">
            {SITE.contact.phoneLabel}
          </a>
        </li>
      </ul>
    </div>
  </section>

  <section class="brief">
    <div class="container">
      <h2>Расскажите о проекте</h2>
      <form class="brief-form" name="brief" method="POST" action="#">
        <div class="row">
          <label>
            <span class="mono">Тип объекта</span>
            <select name="type" required>
              <option value="">—</option>
              <option>Резиденция</option>
              <option>Городская квартира</option>
              <option>Загородный дом</option>
              <option>Лофт</option>
              <option>Public space</option>
            </select>
          </label>
          <label>
            <span class="mono">Метраж</span>
            <select name="area" required>
              <option value="">—</option>
              <option>До 200 m²</option>
              <option>200–400 m²</option>
              <option>400–700 m²</option>
              <option>Больше 700 m²</option>
            </select>
          </label>
        </div>
        <div class="row">
          <label>
            <span class="mono">Бюджет на отделку</span>
            <select name="budget" required>
              <option value="">—</option>
              <option>8–15 млн ₽</option>
              <option>15–25 млн ₽</option>
              <option>25–50 млн ₽</option>
              <option>Больше 50 млн ₽</option>
            </select>
          </label>
          <label>
            <span class="mono">Желаемые сроки старта</span>
            <select name="start" required>
              <option value="">—</option>
              <option>В ближайший месяц</option>
              <option>1–3 месяца</option>
              <option>3–6 месяцев</option>
              <option>Позже</option>
            </select>
          </label>
        </div>
        <label>
          <span class="mono">Имя</span>
          <input type="text" name="name" required />
        </label>
        <label>
          <span class="mono">Контакт &mdash; e-mail или Telegram</span>
          <input type="text" name="contact" required />
        </label>
        <label>
          <span class="mono">Коротко о запросе</span>
          <textarea name="message" rows="4" required></textarea>
        </label>
        <button type="submit" class="btn">Отправить →</button>
      </form>
    </div>
  </section>
</Layout>

<style>
  .hero {
    padding: 128px 0 64px;
  }
  .hero h1 {
    margin-top: 24px;
  }
  .hero .lead {
    font-size: 18px;
    line-height: 1.6;
    margin-top: 32px;
    max-width: 600px;
    color: var(--color-text-muted);
  }

  .channels {
    padding: 64px 0 128px;
    border-bottom: 1px solid var(--color-border);
  }
  .channels ul {
    list-style: none;
  }
  .channels li {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 32px;
    align-items: baseline;
    padding: 32px 0;
    border-top: 1px solid var(--color-border);
  }
  .channels li:last-child {
    border-bottom: 1px solid var(--color-border);
  }
  .channels .big {
    font-size: clamp(24px, 3vw, 36px);
    font-weight: 400;
    letter-spacing: -0.015em;
  }
  .channels .big:hover {
    opacity: 0.5;
  }

  .brief {
    padding: 128px 0;
  }
  .brief > .container > h2 {
    margin-bottom: 64px;
  }
  .brief-form {
    display: grid;
    gap: 40px;
    max-width: 800px;
  }
  .brief-form .row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
  }
  .brief-form label {
    display: grid;
    gap: 8px;
  }
  .brief-form input,
  .brief-form select,
  .brief-form textarea {
    border: none;
    border-bottom: 1px solid var(--color-text);
    background: transparent;
    font-family: var(--font-sans);
    font-size: 16px;
    padding: 8px 0;
    color: var(--color-text);
  }
  .brief-form select {
    appearance: none;
    cursor: pointer;
    background-image: linear-gradient(45deg, transparent 50%, var(--color-text) 50%),
      linear-gradient(135deg, var(--color-text) 50%, transparent 50%);
    background-position: calc(100% - 12px) center, calc(100% - 6px) center;
    background-size: 6px 6px, 6px 6px;
    background-repeat: no-repeat;
    padding-right: 24px;
  }
  .brief-form textarea {
    resize: vertical;
  }
  .brief-form button {
    justify-self: start;
    margin-top: 16px;
  }

  @media (max-width: 720px) {
    .channels li {
      grid-template-columns: 1fr;
      gap: 8px;
      padding: 16px 0;
    }
    .brief-form .row {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
</style>
