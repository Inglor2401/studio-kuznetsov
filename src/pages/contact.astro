---
import Layout from '../layouts/Layout.astro';
import { SITE } from '../data/site';
---

<Layout
  title="Связаться"
  description="Брифинг в шоуруме на Патриарших, по записи. Email, Telegram, телефон или форма брифа."
  pageType="contact"
  ogImage="/og/contact.png"
>
  <section class="hero">
    <div class="container">
      <span class="mono">— Контакт</span>
      <h1>Брифинг занимает 60 минут</h1>
      <p class="lead">
        Шоурум на Патриарших, по записи. Договариваемся через любой удобный канал — почта,
        Telegram, телефон.
      </p>
    </div>
  </section>

  <section class="channels">
    <div class="container">
      <ul>
        <li>
          <span class="mono">Email</span>
          <a href={`mailto:${SITE.contact.email}`} class="big">{SITE.contact.emailLabel}</a>
        </li>
        <li>
          <span class="mono">Telegram</span>
          <a href={SITE.contact.telegram} class="big">{SITE.contact.telegramLabel}</a>
        </li>
        <li>
          <span class="mono">Телефон</span>
          <a href={`tel:${SITE.contact.phone.replace(/\s/g, '')}`} class="big">
            {SITE.contact.phoneLabel}
          </a>
        </li>
      </ul>
    </div>
  </section>

  <section class="brief">
    <div class="container">
      <h2>Расскажите о проекте</h2>
      <p class="brief-intro">
        Пять полей. Этого достаточно, чтобы решить — продолжаем разговор или нет.
        Метраж, бюджет и сроки уточним при первой встрече.
      </p>
      <form class="brief-form" name="brief" method="POST" data-form>
        <div class="row">
          <label>
            <span class="mono">Тип объекта</span>
            <select name="type" required>
              <option value="">—</option>
              <option>Резиденция</option>
              <option>Городская квартира</option>
              <option>Загородный дом</option>
              <option>Лофт</option>
              <option>Public space</option>
            </select>
          </label>
          <label>
            <span class="mono">Локация</span>
            <input type="text" name="location" placeholder="Москва, Патриаршие" required />
          </label>
        </div>
        <label>
          <span class="mono">Имя</span>
          <input type="text" name="name" required />
        </label>
        <label>
          <span class="mono">Контакт &mdash; e-mail или Telegram</span>
          <input type="text" name="contact" required />
        </label>
        <label>
          <span class="mono">Коротко о запросе</span>
          <textarea name="message" rows="4" required placeholder="Семья, сценарий, что важно"></textarea>
        </label>
        <button type="submit" class="btn">Отправить запрос →</button>
      </form>

      <div class="brief-success" data-success hidden>
        <p class="mono">— Принято</p>
        <h3>Спасибо. Артём ответит лично в течение 24 часов.</h3>
        <p>Если запрос срочный — пишите в Telegram <a href={SITE.contact.telegram} class="link">{SITE.contact.telegramLabel}</a>.</p>
      </div>
    </div>
  </section>

  <script>
    const form = document.querySelector('[data-form]') as HTMLFormElement | null;
    const success = document.querySelector('[data-success]') as HTMLDivElement | null;
    if (form && success) {
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        // TODO production: POST в Resend / Formspree / Astro form action endpoint
        // Пока — показываем success state без реальной отправки
        form.hidden = true;
        success.hidden = false;
        success.scrollIntoView({ behavior: 'smooth', block: 'center' });
      });
    }
  </script>
</Layout>

<style>
  .hero {
    padding: 128px 0 64px;
  }
  .hero h1 {
    margin-top: 24px;
  }
  .hero .lead {
    font-size: 18px;
    line-height: 1.6;
    margin-top: 32px;
    max-width: 600px;
    color: var(--color-text-muted);
  }

  .channels {
    padding: 64px 0 128px;
    border-bottom: 1px solid var(--color-border);
  }
  .channels ul {
    list-style: none;
  }
  .channels li {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 32px;
    align-items: baseline;
    padding: 32px 0;
    border-top: 1px solid var(--color-border);
  }
  .channels li:last-child {
    border-bottom: 1px solid var(--color-border);
  }
  .channels .big {
    font-size: clamp(24px, 3vw, 36px);
    font-weight: 400;
    letter-spacing: -0.015em;
  }
  .channels .big:hover {
    opacity: 0.5;
  }

  .brief {
    padding: 128px 0;
  }
  .brief > .container > h2 {
    margin-bottom: 24px;
  }
  .brief-intro {
    font-size: 17px;
    line-height: 1.55;
    color: var(--color-text-muted);
    max-width: 56ch;
    margin-bottom: 64px;
  }
  .brief-success {
    max-width: 640px;
  }
  .brief-success .mono {
    margin-bottom: 24px;
  }
  .brief-success h3 {
    font-size: clamp(24px, 2.6vw, 32px);
    font-weight: 400;
    letter-spacing: -0.015em;
    line-height: 1.2;
    margin-bottom: 24px;
  }
  .brief-success p {
    font-size: 17px;
    line-height: 1.55;
    color: var(--color-text-muted);
  }
  .brief-form {
    display: grid;
    gap: 40px;
    max-width: 800px;
  }
  .brief-form .row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
  }
  .brief-form label {
    display: grid;
    gap: 8px;
  }
  .brief-form input,
  .brief-form select,
  .brief-form textarea {
    border: none;
    border-bottom: 1px solid var(--color-text);
    background: transparent;
    font-family: var(--font-sans);
    font-size: 16px;
    padding: 8px 0;
    color: var(--color-text);
  }
  .brief-form select {
    appearance: none;
    cursor: pointer;
    background-image: linear-gradient(45deg, transparent 50%, var(--color-text) 50%),
      linear-gradient(135deg, var(--color-text) 50%, transparent 50%);
    background-position: calc(100% - 12px) center, calc(100% - 6px) center;
    background-size: 6px 6px, 6px 6px;
    background-repeat: no-repeat;
    padding-right: 24px;
  }
  .brief-form textarea {
    resize: vertical;
  }
  .brief-form button {
    justify-self: start;
    margin-top: 16px;
  }

  @media (max-width: 720px) {
    .channels li {
      grid-template-columns: 1fr;
      gap: 8px;
      padding: 16px 0;
    }
    .brief-form .row {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
</style>
