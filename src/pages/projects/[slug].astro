---
import Layout from '../../layouts/Layout.astro';
import { SITE } from '../../data/site';
import type { Project } from '../../data/site';
import { url } from '../../utils/url';

export function getStaticPaths() {
  return SITE.projects.map((p) => ({
    params: { slug: p.slug },
    props: { project: p },
  }));
}

interface Props {
  project: Project;
}

const { project } = Astro.props;
const idx = SITE.projects.findIndex((p) => p.slug === project.slug);
const next = SITE.projects[(idx + 1) % SITE.projects.length];
const prev = SITE.projects[(idx - 1 + SITE.projects.length) % SITE.projects.length];
---

<Layout
  title={project.title}
  description={project.brief}
  pageType="project"
  project={project}
  ogImage={`/og/projects/${project.slug}.png`}
  preloadImage={project.cover}
>
  <article class="project">
    {/* Breadcrumbs */}
    <nav class="breadcrumbs mono" aria-label="Хлебные крошки">
      <div class="container">
        <a href={url('/')}>STUDIO KUZNETSOV</a>
        <span aria-hidden="true">·</span>
        <a href={url('/projects')}>Объекты</a>
        <span aria-hidden="true">·</span>
        <span aria-current="page">{project.number} / {project.title}</span>
      </div>
    </nav>

    {/* SIGNATURE MOVE — Hero с двумя слоями: floor plan crossfades в cover photo при scroll.
        От чертежа к реализованному объекту. Метафора архитектурного процесса. */}
    <section class="project-hero" data-hero>
      <div class="hero-layer hero-plan" data-plan>
        <img
          src={url(project.floorplan)}
          alt={`Поэтажный план объекта ${project.title}, ${project.area} m². Архитектурный чертёж в масштабе 1:100.`}
        />
        <div class="container plan-meta">
          <p class="mono">{project.number} / Поэтажный план / 1:100</p>
        </div>
      </div>
      <div class="hero-layer hero-photo" data-photo>
        <img
          src={url(project.cover)}
          alt={`${project.title} — ${project.type.toLowerCase()} ${project.area} m² в районе ${project.district}, ${project.location}. ${project.materials}. ${project.year} год.`}
          fetchpriority="high"
          loading="eager"
        />
      </div>
    </section>

    <section class="project-head">
      <div class="container head">
        <div class="title-block">
          <span class="mono">{project.number} / {project.type}</span>
          <h1>{project.title}</h1>
        </div>
        <aside class="mono details">
          <p>{project.location}</p>
          <p>{project.district}</p>
          <p>{project.area} m²</p>
          <p>{project.year}</p>
          <p class="materials">{project.materials}</p>
        </aside>
      </div>
    </section>

    <script>
      // Scroll-morph: floor plan over a faintly-visible photo, photo emerges on scroll.
      // Стартовое состояние: фото проступает на 10% как «бумажный фон», схема — главный слой.
      // Морф завершается к 55% высоты hero — быстрее, чем раньше (было 90%).
      const heroes = document.querySelectorAll<HTMLElement>('[data-hero]');
      const prefersReduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      heroes.forEach((hero) => {
        const plan = hero.querySelector<HTMLElement>('[data-plan]');
        const photo = hero.querySelector<HTMLElement>('[data-photo]');
        if (!plan || !photo) return;
        if (prefersReduce) return; // CSS уже сделает фото видимым, схему скроет

        const photoImg = photo.querySelector<HTMLImageElement>('img');

        // Initial state: схема в полную, фото уже заметно проступает + чуть desaturated
        plan.style.opacity = '1';
        photo.style.opacity = '0.20';
        if (photoImg) photoImg.style.filter = 'grayscale(0.4) brightness(1.05)';

        let ticking = false;
        const update = () => {
          const rect = hero.getBoundingClientRect();
          const heroH = hero.offsetHeight;
          const scrolled = Math.max(0, -rect.top);
          // Раздельные кривые:
          //   photo — завершается на 25% высоты hero (быстрое проявление, как просил)
          //   plan  — уходит плавно до 55% (без резкости, работает как калька)
          // В переходный момент схема становится полупрозрачным наложением
          // поверх уже видимого фото — эффект архитектурной кальки.
          const photoP = Math.min(1, scrolled / (heroH * 0.25));
          const planP = Math.min(1, scrolled / (heroH * 0.55));
          const photoEased = 1 - (1 - photoP) * (1 - photoP);
          plan.style.opacity = String(1 - planP);
          photo.style.opacity = String(0.20 + 0.80 * photoEased);
          if (photoImg) {
            const gs = (0.4 * (1 - photoEased)).toFixed(3);
            const br = (1.05 - 0.05 * photoEased).toFixed(3);
            photoImg.style.filter = `grayscale(${gs}) brightness(${br})`;
          }
          ticking = false;
        };

        window.addEventListener('scroll', () => {
          if (!ticking) {
            requestAnimationFrame(update);
            ticking = true;
          }
        }, { passive: true });

        update();
      });
    </script>

    {/* Brief + story */}
    <section class="text">
      <div class="container">
        <div class="grid">
          <div>
            <span class="mono">— Бриф</span>
            <p class="brief">{project.brief}</p>
          </div>
          <div>
            <span class="mono">— Решение</span>
            <p class="story">{project.story}</p>
          </div>
        </div>
      </div>
    </section>

    {/* Photo essay */}
    <section class="photos">
      {
        project.photos.map((photo, i) => (
          <figure class="photo img-hover">
            <img
              src={url(photo)}
              alt={`${project.title}: интерьер с материалами ${project.materials.toLowerCase()}. Кадр ${i + 1} из ${project.photos.length}.`}
              loading="lazy"
            />
            <figcaption class="mono">
              <span>{project.number}.{String(i + 1).padStart(2, '0')}</span>
              <span>{project.title}</span>
              <span>{project.year}</span>
            </figcaption>
          </figure>
        ))
      }
    </section>

    {/* Floor plan + section drawing — RADICAL MOVE */}
    <section class="drawings">
      <div class="container">
        <header class="section-head">
          <span class="mono">— Архитектурная документация</span>
          <h2>План и разрез</h2>
        </header>
        <div class="grid">
          <figure>
            <span class="mono caption">Поэтажный план / 1:100</span>
            <div class="svg-wrap">
              <img
                src={url(project.floorplan)}
                alt={`Архитектурный поэтажный план объекта ${project.title}, ${project.area} m². Чертёж в масштабе 1:100.`}
                loading="lazy"
              />
            </div>
          </figure>
          <figure>
            <span class="mono caption">Продольный разрез / 1:100</span>
            <div class="svg-wrap">
              <img
                src={url(project.section)}
                alt={`Архитектурный продольный разрез объекта ${project.title}, ${project.area} m². Чертёж в масштабе 1:100.`}
                loading="lazy"
              />
            </div>
          </figure>
        </div>
      </div>
    </section>

    {/* Next/prev */}
    <nav class="next-prev" aria-label="Навигация по проектам">
      <div class="container">
        <a href={url(`/projects/${prev.slug}`)} class="nav-link">
          <span class="mono">← Предыдущий</span>
          <span class="title">{prev.number} / {prev.title}</span>
        </a>
        <a href={url(`/projects/${next.slug}`)} class="nav-link right">
          <span class="mono">Следующий →</span>
          <span class="title">{next.number} / {next.title}</span>
        </a>
      </div>
    </nav>
  </article>
</Layout>

<style>
  .breadcrumbs {
    padding: 16px 0;
    border-bottom: 1px solid var(--color-border);
  }
  .breadcrumbs > .container {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }
  .breadcrumbs span[aria-current],
  .breadcrumbs a {
    color: var(--color-text-muted);
  }
  .breadcrumbs span[aria-current] {
    color: var(--color-text);
  }
  .breadcrumbs a:hover {
    color: var(--color-text);
  }

  /* SIGNATURE — Project hero with floor plan → photo morph */
  .project-hero {
    position: relative;
    width: 100%;
    height: calc(100vh - 64px);
    min-height: 600px;
    overflow: hidden;
    background: var(--color-bg);
  }
  .hero-layer {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    will-change: opacity;
    transition: opacity 50ms linear;
  }
  .hero-plan {
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg);
  }
  .hero-plan img {
    max-width: 78%;
    max-height: 76%;
    width: auto;
    height: auto;
    object-fit: contain;
    filter: contrast(1.05);
  }
  .hero-plan .plan-meta {
    position: absolute;
    inset: auto 0 32px 0;
    display: flex;
    justify-content: center;
  }
  .hero-photo {
    z-index: 1;
  }
  .hero-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Project head — title + details, после hero */
  .project-head {
    padding: 48px 0 96px;
  }
  .project-head .head {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 64px;
    align-items: end;
  }
  .project-head .head h1 {
    margin-top: 16px;
  }
  .project-head .details {
    text-align: right;
    min-width: 320px;
  }
  .project-head .details p {
    margin: 0;
  }
  .project-head .details .materials {
    margin-top: 12px;
    max-width: 320px;
  }

  /* Reduced motion — skip the morph */
  @media (prefers-reduced-motion: reduce) {
    .hero-plan {
      opacity: 0 !important;
    }
    .hero-photo {
      opacity: 1 !important;
    }
    .hero-photo img {
      filter: none !important;
    }
  }

  .text {
    padding: 96px 0;
    border-top: 1px solid var(--color-border);
  }
  .text .grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 96px;
  }
  .text .brief,
  .text .story {
    margin-top: 16px;
    font-size: 18px;
    line-height: 1.6;
    max-width: 56ch;
  }
  .text .brief {
    color: var(--color-text-muted);
  }

  .photos {
    display: grid;
    gap: 0;
  }
  .photo {
    position: relative;
    overflow: hidden;
    background: var(--color-surface-alt);
  }
  .photo img {
    width: 100%;
    height: 88vh;
    object-fit: cover;
    display: block;
  }
  .photo figcaption {
    position: absolute;
    bottom: 24px;
    right: 32px;
    background: var(--color-bg);
    padding: 8px 12px;
    display: flex;
    gap: 16px;
  }

  .drawings {
    padding: 128px 0;
    border-top: 1px solid var(--color-border);
  }
  .drawings .grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
  }
  .drawings figure {
    display: grid;
    gap: 16px;
  }
  .drawings .svg-wrap {
    aspect-ratio: 4 / 3;
    background: var(--color-surface-alt);
    border: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .drawings .svg-wrap img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .next-prev {
    padding: 64px 0 128px;
    border-top: 1px solid var(--color-border);
  }
  .next-prev > .container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }
  .nav-link {
    display: grid;
    gap: 8px;
  }
  .nav-link .title {
    font-size: 24px;
    font-weight: 500;
    letter-spacing: -0.01em;
  }
  .nav-link.right {
    text-align: right;
  }

  @media (max-width: 720px) {
    .project-hero {
      height: calc(100vh - 56px);
      min-height: 480px;
    }
    .hero-plan img {
      max-width: 92%;
      max-height: 70%;
    }
    .project-head {
      padding: 32px 0 64px;
    }
    .project-head .head {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .project-head .details {
      text-align: left;
    }
    .text .grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
    .photo img {
      height: 56vh;
    }
    .drawings .grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
    .next-prev > .container {
      grid-template-columns: 1fr;
    }
    .nav-link.right {
      text-align: left;
    }
  }
</style>
