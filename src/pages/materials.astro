---
import Layout from '../layouts/Layout.astro';
import { SITE } from '../data/site';
---

<Layout
  title="Материалы"
  description="Палитра материалов и поставщиков, с которыми работает STUDIO KUZNETSOV. Дуб из Бургундии, мрамор Каррара, известковая штукатурка из Венеции."
  pageType="materials"
  ogImage="/og/default.png"
>
  <section class="hero">
    <div class="container">
      <span class="mono">— Материалы</span>
      <h1>Десять материалов, которые повторяются от проекта к проекту</h1>
      <p class="lead">
        Мы работаем с узким набором поставщиков. Каждый материал тестируется на одном проекте до
        включения в постоянную палитру. Список ниже — то, что прошло этот фильтр и осталось в
        работе на десять лет.
      </p>
    </div>
  </section>

  <section class="grid-section">
    <div class="container">
      <ul class="materials-grid">
        {
          SITE.materials.map((m) => (
            <li>
              <div class="img img-hover">
                <img
                  src={m.image}
                  alt={`${m.name} — материал из ${m.origin}, ${m.source}. Используется в проектах ${m.usedIn.join(', ')}.`}
                  loading="lazy"
                />
              </div>
              <div class="meta">
                <p class="mono origin">{m.origin}</p>
                <h3>{m.name}</h3>
                <p class="mono source">{m.source}</p>
                <p class="mono used">В&nbsp;проектах · {m.usedIn.join(', ')}</p>
              </div>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</Layout>

<style>
  .hero {
    padding: 128px 0 64px;
  }
  .hero h1 {
    margin-top: 24px;
    max-width: 1100px;
  }
  .hero .lead {
    font-size: 18px;
    line-height: 1.6;
    margin-top: 32px;
    max-width: 700px;
    color: var(--color-text-muted);
  }

  .grid-section {
    padding: 64px 0 128px;
  }
  .materials-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 96px 32px;
    list-style: none;
  }
  .img {
    aspect-ratio: 1 / 1;
    background: var(--color-surface-alt);
  }
  .meta {
    display: grid;
    gap: 8px;
    margin-top: 20px;
  }
  .meta .origin {
    margin: 0;
    color: var(--color-text);
  }
  .meta h3 {
    font-size: 22px;
    font-weight: 500;
    letter-spacing: -0.01em;
  }
  .meta .source,
  .meta .used {
    margin: 0;
  }
  .meta .source {
    color: var(--color-text-muted);
  }

  @media (max-width: 720px) {
    .materials-grid {
      grid-template-columns: 1fr;
      gap: 64px;
    }
  }
</style>
