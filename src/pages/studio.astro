---
import Layout from '../layouts/Layout.astro';
import { SITE } from '../data/site';
---

<Layout title="Студия" description={SITE.studio.bioShort}>
  <section class="hero">
    <div class="container">
      <span class="mono">— Студия</span>
      <h1>Архитектура жилых пространств для тех, кто строит дом надолго</h1>
    </div>
  </section>

  <figure class="hero-image img-hover">
    <img src="/images/studio/portrait-in-situ.avif" alt="Артём Кузнецов в одном из проектов студии" />
  </figure>

  <section class="bio">
    <div class="container">
      <div class="grid">
        <aside class="side">
          <figure class="portrait">
            <img src="/images/studio/portrait.avif" alt="Артём Кузнецов" />
          </figure>
          <div class="mono">
            <p>{SITE.studio.principal}</p>
            <p>{SITE.studio.role}</p>
            <p>{SITE.studio.location}, c {SITE.studio.foundedYear}</p>
          </div>
        </aside>
        <div class="text">
          {SITE.studio.bio.split('\n\n').map((paragraph) => <p>{paragraph}</p>)}
        </div>
      </div>
    </div>
  </section>

  <section class="approach">
    <div class="container--text">
      <header class="lede">
        <h2>Полный цикл — от 14 до 22 месяцев</h2>
        <p>
          Пять фаз честно отражают, как идёт работа.
          Длительность каждой подбирается под объект,
          но порядок и плотность — постоянные.
        </p>
      </header>
      <ol class="phases">
        {
          SITE.approach.map((step) => (
            <li>
              <span class="mono duration">{step.duration}</span>
              <div class="content">
                <h3>{step.title}</h3>
                <p>{step.description}</p>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <section class="press">
    <div class="container--text">
      <h2>Признание</h2>
      <ul>
        {
          SITE.press.map((item) => (
            <li>
              <div class="meta">
                <span class="mono pub">{item.publication}</span>
                <span class="mono year">{item.year}</span>
              </div>
              <span class="title">{item.title}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="faq">
    <div class="container--text">
      <h2>Частые вопросы</h2>
      <div class="faq-list">
        {
          SITE.faq.map((item) => (
            <details>
              <summary>
                <span class="q">{item.question}</span>
                <span class="plus" aria-hidden="true">+</span>
              </summary>
              <p>{item.answer}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    padding: 128px 0 64px;
  }
  .hero h1 {
    margin-top: 24px;
    max-width: 1200px;
  }

  .hero-image {
    width: 100%;
    height: 70vh;
    overflow: hidden;
    background: var(--color-surface-alt);
    margin: 0;
  }
  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .bio {
    padding: 96px 0 128px;
  }
  .bio .grid {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 96px;
  }
  .bio .side {
    display: grid;
    gap: 24px;
  }
  .bio .side .portrait {
    margin: 0;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: var(--color-surface-alt);
  }
  .bio .side .portrait img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .bio .side .mono p {
    margin: 0;
  }
  .bio .text p {
    font-size: 18px;
    line-height: 1.6;
    max-width: 700px;
    margin-bottom: 24px;
  }
  .bio .text p:last-child {
    margin-bottom: 0;
  }

  .approach {
    padding: 160px 0;
    border-top: 1px solid var(--color-border);
  }
  .lede {
    margin-bottom: 96px;
    max-width: 880px;
  }
  .lede h2 {
    font-size: clamp(28px, 3vw, 44px);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.15;
  }
  .lede p {
    font-size: 17px;
    line-height: 1.6;
    color: var(--color-text-muted);
    max-width: 56ch;
    margin-top: 24px;
  }
  .phases {
    list-style: none;
  }
  .phases li {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 48px;
    padding: 40px 0;
    border-top: 1px solid var(--color-border);
    align-items: start;
  }
  .phases li:last-child {
    border-bottom: 1px solid var(--color-border);
  }
  .phases .duration {
    padding-top: 8px;
  }
  .phases .content h3 {
    font-size: 22px;
    font-weight: 500;
    letter-spacing: -0.01em;
    margin-bottom: 12px;
  }
  .phases .content p {
    font-size: 16px;
    line-height: 1.55;
    color: var(--color-text-muted);
  }

  .press {
    padding: 160px 0;
    border-top: 1px solid var(--color-border);
  }
  .press > .container--text > h2 {
    margin-bottom: 64px;
  }
  .press ul {
    list-style: none;
  }
  .press li {
    display: block;
    padding: 32px 0;
    border-top: 1px solid var(--color-border);
  }
  .press li:last-child {
    border-bottom: 1px solid var(--color-border);
  }
  .press .meta {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 24px;
    margin-bottom: 8px;
  }
  .press .pub {
    font-weight: 500;
  }
  .press .title {
    font-size: 22px;
    font-weight: 400;
    letter-spacing: -0.015em;
    line-height: 1.25;
    display: block;
  }

  .faq {
    padding: 160px 0;
    border-top: 1px solid var(--color-border);
  }
  .faq > .container--text > h2 {
    margin-bottom: 64px;
  }
  .faq-list {
    list-style: none;
  }
  .faq details {
    border-top: 1px solid var(--color-border);
    padding: 32px 0;
  }
  .faq details:last-child {
    border-bottom: 1px solid var(--color-border);
  }
  .faq summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    font-size: clamp(20px, 2.2vw, 28px);
    font-weight: 400;
    letter-spacing: -0.015em;
    list-style: none;
    gap: 32px;
  }
  .faq summary::-webkit-details-marker {
    display: none;
  }
  .faq .plus {
    font-family: var(--font-mono);
    font-size: 24px;
    font-weight: 400;
    color: var(--color-text-muted);
    transition: transform 200ms var(--ease-out);
    flex-shrink: 0;
  }
  .faq details[open] .plus {
    transform: rotate(45deg);
  }
  .faq details p {
    margin-top: 20px;
    font-size: 16px;
    line-height: 1.6;
    max-width: 60ch;
    color: var(--color-text-muted);
  }

  @media (max-width: 720px) {
    .bio .grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .lede {
      margin-bottom: 56px;
    }
    .phases li {
      grid-template-columns: 1fr;
      gap: 8px;
      padding: 24px 0;
    }
    .press li {
      padding: 24px 0;
    }
    .press .title {
      font-size: 18px;
    }
  }
</style>
